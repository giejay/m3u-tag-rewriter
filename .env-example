# Dropbox app credentials
# Create an app at https://www.dropbox.com/developers/apps
# → Scoped access → Full Dropbox (or App folder) → set name
# → Copy "App key" and "App secret" below

DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# Source playlists – comma-separated list of direct-download M3U URLs (dl=1)
# Example:
#   DROPBOX_PLAYLISTS=https://www.dropbox.com/.../foo.m3u?rlkey=...&dl=1,https://...
DROPBOX_PLAYLISTS=

# Output filename suffix (inserted before .m3u)
# foo.m3u  →  foo-include-tvstream-tag.m3u
# DROPBOX_OUTPUT_SUFFIX=-include-tvstream-tag

# Where to cache the OAuth token between runs
# DROPBOX_TOKEN_FILE=/data/dropbox_token.json

# Cron schedule (standard 5-field cron expression, container TZ applies)
# Default: every night at 01:00
CRON_SCHEDULE=0 1 * * *
